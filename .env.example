# Copy this to .env.local and fill in your keys
# These are entered in the Settings UI — no server-side env vars needed
# But you can set them here as defaults if self-hosting

# Optional: pre-configure Groq key server-side (not recommended for public deployments)
# GROQ_API_KEY=gsk_...

# Optional: pre-configure Tavily key server-side
# TAVILY_API_KEY=tvly-...

# Next.js
NEXT_PUBLIC_APP_NAME=Jarvis
NEXT_PUBLIC_APP_VERSION=2.0.0
